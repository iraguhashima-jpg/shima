{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],

    "ignoreDeprecations": "6.0"
  },

  "include": [
    "src/**/*"
  ]
}